{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "IoTCorePermissions",
      "Effect": "Allow",
      "Action": [
        "iot:Connect",
        "iot:Publish",
        "iot:Subscribe",
        "iot:Receive"
      ],
      "Resource": [
        "arn:aws:iot:${region}:*:client/${utility_name}-*",
        "arn:aws:iot:${region}:*:topic/grid/telemetry/*",
        "arn:aws:iot:${region}:*:topicfilter/grid/telemetry/*",
        "arn:aws:iot:${region}:*:topicfilter/grid/commands/*"
      ],
      "Condition": {
        "Bool": {
          "iot:Connection.Thing.IsAttached": "true"
        }
      }
    },
    {
      "Sid": "ThingShadowPermissions",
      "Effect": "Allow",
      "Action": [
        "iot:GetThingShadow",
        "iot:UpdateThingShadow"
      ],
      "Resource": [
        "arn:aws:iot:${region}:*:thing/${utility_name}-*"
      ]
    }
  ]
}
